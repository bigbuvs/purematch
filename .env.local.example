# ─── InsForge / Backend ───────────────────────────────────────────────────────
# Copia este archivo como .env.local y completa los valores desde tu dashboard
# InsForge → Settings → API

# URL pública del proyecto InsForge (sin barra al final)
NEXT_PUBLIC_INSFORGE_URL=https://j8rrdq52.us-east.insforge.app

# Anon key (segura para el browser) — InsForge Dashboard → Settings → API
NEXT_PUBLIC_INSFORGE_ANON_KEY=

# Service role key (solo servidor/backend) — InsForge Dashboard → Settings → API
INSFORGE_SERVICE_ROLE_KEY=

# Conexión directa a PostgreSQL (para migraciones y scripts locales)
DATABASE_URL=postgresql://postgres:ac5c26b74ba06fd5c1373f84614c2184@j8rrdq52.us-east.database.insforge.app:5432/insforge?sslmode=require

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
